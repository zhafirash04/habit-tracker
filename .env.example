# Server
PORT=8080
APP_ENV=development

# Database
DATABASE_URL=habitflow.db

# JWT
# Production: gunakan secret kuat (>=32 karakter, kombinasi huruf besar/kecil + angka)
JWT_SECRET=ChangeThisToAStrongSecretWithUpperLower123

# Security / API hardening
# Daftar origin dipisah koma (gunakan domain frontend production + localhost dev)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,https://zhafirash04.github.io
MAX_BODY_BYTES=1048576

# VAPID Keys for Web Push Notifications
# Generate with: go run cmd/generate-vapid/main.go
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@habitflow.app
